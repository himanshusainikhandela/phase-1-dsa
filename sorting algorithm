(3): SELECTION SORT


#include <iostream>
using namespace std;

// selection sort
int main()
{
    int arr[5] = {5,4,3,2,1};
    int n = 5;

    // assume minimum element index
    int min_ele;

    for(int i = 0; i < n-1; i++)
    {
        min_ele = i;

        for(int j = i+1; j < n; j++)
        {
            if(arr[j] < arr[min_ele])
            {
                min_ele = j;
            }
        }

        swap(arr[i], arr[min_ele]);
    }

    // display sorted array
    for(int i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }

    return 0;
}


