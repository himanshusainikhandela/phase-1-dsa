#include <iostream>
using namespace std;
//Encapsulation & Abstarction
class Student
{
    string name;
    int age;
    
    public:
    //setter function:set the private data member
    void setter(string n,int a)
    {
        name=n;
        age=a;
    }
    //getter function:return the private data member value
    int getter()
    {
        return age;
    }
    void display()
    {
        cout<<name<<" "<<age<<endl;
    }
    
};
int main()
{
    Student obj1;
    obj1.setter("Hitesh",25);
    cout<<obj1.getter();
}
