max sum subarray size of k


#include <iostream>
using namespace std;

int main() {
    int arr[] = {2, 1, 5, 1, 3, 2};
    int n = 6;
    int k = 3;

    int maxSum = 0;
    int windowSum = 0;

    // Calculate sum of first window
    for(int i = 0; i < k; i++) {
        windowSum += arr[i];
    }

    maxSum = windowSum;

    // Sliding window
    for(int i = k; i < n; i++) {
        windowSum = windowSum - arr[i - k] + arr[i];

        if(windowSum > maxSum) {
            maxSum = windowSum;
        }
    }

    cout << "Maximum sum of subarray of size " << k << " is: " << maxSum;

    return 0;
}
